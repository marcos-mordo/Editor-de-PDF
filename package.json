{
  "name": "editor-pdf",
  "private": true,
  "version": "0.9.0",
  "description": "Editor de PDF profesional multiplataforma - alternativa libre a Adobe Acrobat",
  "author": "Marco",
  "main": "dist-electron/main.js",
  "type": "module",
  "scripts": {
    "icons": "node scripts/build-icon.mjs",
    "dev": "vite",
    "build": "npm run icons && tsc -b && vite build",
    "test": "vitest run",
    "test:watch": "vitest",
    "smoke-test": "node scripts/smoke-test.mjs",
    "preview": "vite preview",
    "pack": "npm run build && electron-builder --dir",
    "dist": "npm run build && electron-builder",
    "dist:win": "npm run build && electron-builder --win --dir && node scripts/embed-icon.mjs && electron-builder --win nsis portable --prepackaged release/win-unpacked",
    "dist:mac": "npm run build && electron-builder --mac",
    "dist:linux": "npm run build && electron-builder --linux",
    "dist:all": "npm run build && electron-builder -mwl"
  },
  "dependencies": {
    "@dnd-kit/core": "^6.1.0",
    "@dnd-kit/sortable": "^8.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@signpdf/placeholder-plain": "^3.3.0",
    "@signpdf/signer-p12": "^3.3.0",
    "@signpdf/signpdf": "^3.3.0",
    "aes-js": "^3.1.2",
    "clsx": "^2.1.1",
    "docx": "^9.0.2",
    "file-saver": "^2.0.5",
    "jspdf": "^2.5.2",
    "jszip": "^3.10.1",
    "lucide-react": "^0.460.0",
    "node-forge": "^1.4.0",
    "pdf-lib": "^1.17.1",
    "pdfjs-dist": "^4.8.69",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-hot-toast": "^2.4.1",
    "spark-md5": "^3.0.2",
    "tesseract.js": "^5.1.1",
    "xlsx": "^0.18.5",
    "zustand": "^5.0.1"
  },
  "devDependencies": {
    "@resvg/resvg-js": "^2.6.2",
    "@types/aes-js": "^3.1.4",
    "@types/file-saver": "^2.0.7",
    "@types/node": "^22.9.0",
    "@types/node-forge": "^1.3.14",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@types/spark-md5": "^3.0.5",
    "@vitejs/plugin-react": "^4.3.3",
    "@vitest/ui": "^4.1.9",
    "autoprefixer": "^10.4.20",
    "electron": "^33.2.0",
    "electron-builder": "^25.1.8",
    "png-to-ico": "^3.0.1",
    "postcss": "^8.4.49",
    "resedit": "^3.0.2",
    "tailwindcss": "^3.4.15",
    "typescript": "^5.6.3",
    "vite": "^5.4.11",
    "vite-plugin-electron": "^0.28.8",
    "vite-plugin-electron-renderer": "^0.14.6",
    "vitest": "^4.1.9",
    "ws": "^8.21.0"
  },
  "build": {
    "appId": "com.marco.editorpdf",
    "productName": "Editor de PDF",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "dist-electron/**/*"
    ],
    "extraResources": [
      {
        "from": "build/icon.png",
        "to": "icon.png"
      },
      {
        "from": "build/icon.ico",
        "to": "icon.ico"
      }
    ],
    "win": {
      "icon": "build/icon.ico",
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        },
        {
          "target": "portable",
          "arch": [
            "x64"
          ]
        }
      ],
      "signAndEditExecutable": false
    },
    "portable": {
      "artifactName": "Editor-de-PDF-Portable-${version}.exe"
    },
    "mac": {
      "icon": "build/icon.png",
      "target": [
        {
          "target": "dmg",
          "arch": [
            "x64",
            "arm64"
          ]
        }
      ],
      "category": "public.app-category.productivity"
    },
    "linux": {
      "icon": "build/icon.png",
      "target": [
        "AppImage",
        "deb"
      ],
      "category": "Office"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "installerIcon": "build/icon.ico",
      "uninstallerIcon": "build/icon.ico",
      "installerHeaderIcon": "build/icon.ico",
      "shortcutName": "Editor de PDF"
    }
  }
}
